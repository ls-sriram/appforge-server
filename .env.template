# ──────────────────────────────────────────────────────────────────────────
# AppForge Backend — Local Environment Template
# ──────────────────────────────────────────────────────────────────────────
# Copy to .env.local and fill in values:
#   cp .env.template .env.local
#
# Usage:
#   source .env.local
#   make local
# ──────────────────────────────────────────────────────────────────────────

# ─── Runtime ─────────────────────────────────────────────────────────────
export PORT=8080
export HOST=0.0.0.0
export NODE_ENV=development
export APP_PUBLIC_URL=http://localhost:8080
export CORS_ALLOWED_ORIGINS='["http://localhost:3000","http://localhost:3001"]'
export INTERNAL_SECRET=dev-secret
export EARLY_ACCESS_ENABLED=true

# ─── Database ────────────────────────────────────────────────────────────
# Options: sql, firestore, memory
export DATABASE_PRIMARY=sql

# PostgreSQL connection (for DATABASE_PRIMARY=sql)
export DATABASE_SQL_URL=jdbc:postgresql://localhost:5432/appforge
export DATABASE_SQL_USER=user1
export DATABASE_SQL_PASSWORD=password1
export DATABASE_SQL_POOL_SIZE=5

# Optional cache layer (unset or "none" to disable)
# export DATABASE_CACHE=firestore

# ─── Firebase (optional — only needed for auth routes) ───────────────────
export FIREBASE_PROJECT_ID=
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ─── Dodo Payments (test mode) ──────────────────────────────────────────
export DODO_PAYMENTS_BASE_URL=https://test.dodopayments.com
export DODO_PAYMENTS_API_KEY=

# ─── Uploads ─────────────────────────────────────────────────────────────
export UPLOADS_BUCKET=
export UPLOAD_MAX_BYTES=10485760

# ─── OpenAI (optional — only needed for AI review routes) ────────────────
export OPENAI_API_KEY=
export OPENAI_MODEL=gpt-4o-mini

# ─── Email (optional) ────────────────────────────────────────────────────
export EMAIL_API_KEY=

# ─── Billing ─────────────────────────────────────────────────────────────
export TRIAL_DURATION_DAYS=7
